# Copy this file to secrets.toml and fill in your own values.
# NEVER commit secrets.toml to git — it is already in .gitignore.

MONGO_URI            = "mongodb+srv://<user>:<password>@<cluster-url>/churnDB?retryWrites=true&w=majority"
GOOGLE_CLIENT_ID     = "your-google-oauth-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET = "your-google-oauth-client-secret"
REDIRECT_URI         = "http://localhost:8501"
COOKIE_KEY           = "generate-a-long-random-string-here"
